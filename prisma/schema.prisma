generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String   @id @default(cuid())
  name              String
  email             String   @unique
  phone             String?
  company           String?
  password          String
  resetToken        String?
  resetTokenExpiry  DateTime?
  role              String   @default("client")
  status            String   @default("actif") // actif | inactif
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  devis             Devis[]
  orders            Order[]
  tickets           Ticket[]
  invoices          Invoice[]
  contacts          Contact[]
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  label       String
  description String?
  color       String   @default("#8B5CF6")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@map("roles")
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  read      Boolean  @default(false)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
}

model Devis {
  id         String   @id @default(cuid())
  reference  String   @unique
  name       String
  email      String
  phone      String
  company    String?
  service    String
  budget     String?
  description String
  status     String   @default("en_attente") // en_attente | accepte | refuse | gagne | perdu
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Newsletter {
  id        String   @id @default(cuid())
  email     String   @unique
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Product {
  id           String  @id @default(cuid())
  slug         String  @unique
  name         String
  category     String
  price        Int
  originalPrice Int?
  image        String
  rating       Float   @default(0)
  reviews      Int     @default(0)
  stock        Int     @default(0)
  description  String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  orderItems   OrderItem[]
}

model Order {
  id         String   @id @default(cuid())
  reference  String   @unique
  firstName  String
  lastName   String
  email      String
  phone      String
  address    String
  city       String
  notes      String?
  total      Int
  status     String   @default("en_attente") // en_attente | confirmee | livree | annulee
  userId     String?
  user       User?    @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  items      OrderItem[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int     @default(1)
  price     Int

  @@unique([orderId, productId])
}

model Service {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  shortTitle     String
  icon           String
  description    String
  longDescription String
  image          String
  heroImage      String
  color          String
  subServices    Json     @default("[]")
  technologies   String[]
  faqs           Json     @default("[]")
  orderIndex     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model BlogArticle {
  id        String   @id @default(cuid())
  slug      String   @unique
  title     String
  category  String
  author    String
  date      DateTime
  readTime  Int
  image     String
  excerpt   String
  content   String
  featured  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Course {
  id          String  @id @default(cuid())
  slug        String  @unique
  title       String
  instructor  String
  level       String  // Débutant | Intermédiaire | Avancé
  duration    String
  modules     Int
  price       Int
  rating      Float   @default(0)
  students    Int     @default(0)
  image       String
  domain      String
  badge       String?
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Project {
  id           String   @id @default(cuid())
  slug         String   @unique
  title        String
  client       String
  year         Int
  domain       String
  image        String
  description  String
  technologies String[]
  results       String[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Testimonial {
  id     String @id @default(cuid())
  name   String
  role   String
  text   String
  rating Int    @default(5)
  avatar String
  orderIndex Int @default(0)
  createdAt DateTime @default(now())
}

model TeamMember {
  id         String   @id @default(cuid())
  name       String
  role       String
  bio        String
  image      String
  specialties String[]
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())
}

model Ticket {
  id        String   @id @default(cuid())
  subject   String
  category  String
  priority  String   @default("moyenne") // basse | moyenne | haute | critique
  status    String   @default("ouvert") // ouvert | en_cours | resolu | ferme
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages  TicketMessage[]
}

model TicketMessage {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  content   String
  authorId  String
  createdAt DateTime @default(now())
}

model Invoice {
  id         String   @id @default(cuid())
  reference  String   @unique
  amount     Int
  status     String   @default("impayee") // impayee | payee | annulee
  dueDate    DateTime
  paidAt     DateTime?
  pdfUrl     String?
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model SiteSettings {
  id                String   @id @default("singleton")
  siteName          String   @default("Innov'Yed Solutions")
  siteTagline       String   @default("Solutions Innovantes")
  badgeText         String   @default("10 Domaines / 127+ Projets Livrés")
  projectsDelivered Int      @default(127)
  satisfiedClients  Int      @default(89)
  yearsExperience   Int      @default(4)
  satisfactionRate  Int      @default(98)
  phone             String   @default("+225 07 09 78 56 24")
  email             String   @default("contact@innovyed.com")
  whatsapp          String   @default("+225 07 09 78 56 24")
  address           String   @default("Abidjan, Côte d'Ivoire")
  facebook          String?
  twitter           String?
  linkedin          String?
  instagram         String?
  youtube           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ProcessStep {
  id          String   @id @default(cuid())
  title       String
  description String
  duration    String
  icon        String
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TechStack {
  id         String   @id @default(cuid())
  name       String
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())
}

model HeroImage {
  id         String   @id @default(cuid())
  url        String
  alt        String?
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())
}

model CompanyAdvantage {
  id          String   @id @default(cuid())
  title       String
  description String
  icon        String
  color       String
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FAQ {
  id          String   @id @default(cuid())
  question    String
  answer      String
  category    String   @default("general")
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CompanyValue {
  id          String   @id @default(cuid())
  title       String
  description String
  icon        String
  color       String
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model CompanyTimeline {
  id          String   @id @default(cuid())
  year        String
  title       String
  description String
  icon        String
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Certification {
  id         String   @id @default(cuid())
  name       String
  icon       String?
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())
}

model DevisService {
  id         String   @id @default(cuid())
  name       String
  icon       String
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())
}

model DevisBudget {
  id         String   @id @default(cuid())
  label      String
  value      String
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())
}

model DevisTimeline {
  id         String   @id @default(cuid())
  label      String
  value      String
  orderIndex Int      @default(0)
  createdAt  DateTime @default(now())
}
